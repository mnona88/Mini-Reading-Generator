{
  "version": 2,
  "builds": [
    { "src": "api/generate-reading.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/generate-reading", "methods": ["POST"], "dest": "/api/generate-reading.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
